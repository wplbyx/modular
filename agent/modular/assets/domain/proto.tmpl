// proto/{{DOMAIN}}/{{SURFACE}}.proto - template for `service` / `surface`.
// Placeholder tokens the agent fills:
//   {{DOMAIN}}        snake_case name (order, user) -> proto/common/internal package partition
//   {{SURFACE}}       interface surface (public, admin, management, platform)
//   {{SERVICE_PASCAL}} generated service name, e.g. UserService or UserAdminService
//   {{GO_PACKAGE}}    e.g. {{project}}/common/{{DOMAIN}}
// After editing run `gen` to produce common/{{DOMAIN}}/... generated files.
// Do not add v1/v2 directories unless the corresponding
// internal/{{DOMAIN}}/api/{{SURFACE}} and app/{{SURFACE}} packages are split.

syntax = "proto3";

package {{DOMAIN}};

option go_package = "{{GO_PACKAGE}}";

// {{SERVICE_PASCAL}} is the cross-module interface for this domain surface.
// Other domains call it via the generated client; never import internal/.
service {{SERVICE_PASCAL}} {
  // rpc Example(ExampleRequest) returns (ExampleResponse);
}

message ExampleRequest {
  string id = 1;
}

message ExampleResponse {
  string id = 1;
}
