// internal/infra/redis_resource.go - template for the `resource redis` command.
// Wraps a go-redis client as a core.Resource. Inject the returned client into
// repositories; do not rely on redis.GetClient() global from business code.
// Tokens: {{PROJECT}}
package infra

import (
	"context"
	"fmt"

	goredis "github.com/redis/go-redis/v9"

	"github.com/wplbyx/modular/packages/config"
	"github.com/wplbyx/modular/packages/core"
	"github.com/wplbyx/modular/packages/infra/cache/redis"
)

type RedisResource struct {
	cfg    *config.Redis
	client goredis.UniversalClient
}

func NewRedisResource(cfg *config.Redis) *RedisResource {
	return &RedisResource{cfg: cfg}
}

func (r *RedisResource) Name() string { return "redis" }

func (r *RedisResource) Setup(ctx context.Context) error {
	client, err := redis.NewRedisClient(r.cfg)
	if err != nil {
		return fmt.Errorf("redis setup: %w", err)
	}
	r.client = client
	return nil
}

func (r *RedisResource) Close(ctx context.Context) error {
	if r.client == nil {
		return nil
	}
	return r.client.Close()
}

// Client exposes the connection for repository injection.
func (r *RedisResource) Client() goredis.UniversalClient { return r.client }

var _ core.Resource = (*RedisResource)(nil)
